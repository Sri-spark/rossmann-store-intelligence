# ──────────────────────────────────────────────────────────────────────────
# Rossmann Store Intelligence — environment template.
# Copy to `.env` and adjust. NEVER commit `.env` (it is git-ignored).
# ──────────────────────────────────────────────────────────────────────────

# ── Source OLTP: MySQL ────────────────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=rossmann
MYSQL_USER=rossmann
MYSQL_PASSWORD=rossmann_pw
MYSQL_ROOT_PASSWORD=root_pw

# ── Warehouse + Airflow metadata: PostgreSQL ──────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_pw
# Airflow metadata database (created by the postgres image)
POSTGRES_AIRFLOW_DB=airflow
# Analytics warehouse database (created by docker-entrypoint-initdb.d)
POSTGRES_WAREHOUSE_DB=warehouse

# ── Airflow ───────────────────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Fernet key for connection/variable encryption. Generate a real one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=changeme_generate_a_real_fernet_key_for_production

# ── Evidence BI ───────────────────────────────────────────────────────────
EVIDENCE_PORT=3001
